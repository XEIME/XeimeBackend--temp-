generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum MarkType {
  AC1
  AC2
  AC3
  AT
}

enum AttendenceStatus {
  PRESENTE
  FALTA 
  ATRASO 
}

model School {
  id String @id @default(uuid())
  name String @unique
  address String

  users User[]

  schoolclasses SchoolClass[]
}

model User {
  id String @id @default(uuid())
  name String
  email String? @unique
  phone String? @unique
  password String
  avatarUrl String? 

  role Role @default(STUDENT)

  bio String?
  address String?
  birthday DateTime?

  settings Settings?

  schoolId String?
  school School? @relation(fields: [schoolId], references: [id])

  parentId String? @map("parent_id")
  parent User? @relation("familyLink", fields: [parentId], references: [id])
  children User[] @relation("familyLink")

  classId String?
  class SchoolClass? @relation(fields: [classId], references: [id])

  mark Mark[] @relation("studentMarks")

  attendance Attendance[] @relation("StudentAttendance")
}

model Settings {
  id String @id @default(uuid())
  notifications Boolean @default(true)
  darkMode Boolean @default(false)
  language String @default("pt-MZ")

  userId String @unique
  user User @relation(fields: [userId], references: [id])
}

model SchoolClass {
  id String @id @default(uuid())
  name String

  schoolId String
  school School @relation(fields: [schoolId], references: [id])

  gradeId String
  grade SchoolGrade @relation(fields: [gradeId], references: [id])

  user User[]

  classProgress ClassProgress[]

  homeWorks HomeWork[]

  attendance Attendance[]

}

model SchoolGrade {
  id String @id @default(uuid())
  name String @unique

  schoolclasses SchoolClass[]

  academicPlan AcademicPlan[]
}

model Subject {
  id  String @id @default(uuid())
  name String @unique

  academicplan AcademicPlan[]

  mark Mark[]

  homeWork HomeWork[]

  attendance Attendance[]
}

model AcademicPlan {
  id String @id @default(uuid())
  trimester Int
  year Int

  subjectId String
  subject Subject @relation(fields: [subjectId], references: [id])

  gradeId String
  schoolGrade SchoolGrade @relation(fields: [gradeId], references: [id])

  topic Topic[]

  @@unique([subjectId, gradeId, trimester, year])
}

model Topic {
  id String @id @default(uuid())
  weekNumber Int
  unit String
  content String[]
  objectives String[]
  numberOfLessons Int @default(1)

  planId String
  academicPlan AcademicPlan @relation(fields: [planId], references: [id])

  classProgress ClassProgress[]
}

model ClassProgress {
  id String @id @default(uuid())

  classId String
  schoolClass SchoolClass @relation(fields: [classId], references: [id])

  topicId String
  topic Topic @relation(fields: [topicId], references: [id])

  completedAt DateTime @default(now())

  @@unique([classId, topicId])
}

model Mark {
  id String @id @default(uuid())
  type MarkType
  value Float
  trimester Int
  year Int

  studentId String
  student User @relation("studentMarks", fields: [studentId], references: [id])

  subjectId String
  subject Subject @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, trimester, year, type])
}

model HomeWork {
  id String @id @default(uuid())
  title String
  description String
  dueData DateTime

  subjectId String
  suject Subject @relation(fields: [subjectId], references: [id])

  classId String
  class SchoolClass @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
}

model Attendance {
  id String @id @default(uuid())
  date DateTime @default(now())
  status AttendenceStatus
  note String?

  isPublished Boolean @default(false)

  studentId String
  student User @relation("StudentAttendance", fields: [studentId], references: [id])

  classid String
  class SchoolClass @relation(fields: [classid], references: [id])

  subjectId String
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date])
}